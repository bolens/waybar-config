{
  "custom/notifications": {
    "format": "{0}{icon}",
    "return-type": "json",
    "signal": 10,
    "interval": "once",
    "escape": true,
    "exec": "$WAYBAR_HOME/scripts/notifications/notifications-status.sh",
    "format-icons": {
      "notification": "󰂚",
      "none": "󰂜",
      "dnd-notification": "󰂛",
      "dnd-none": "󰂛",
      "inhibited-notification": "󰂛",
      "inhibited-none": "󰂛",
      "dnd-inhibited-notification": "󰂛",
      "dnd-inhibited-none": "󰂛",
      "unknown": "󰂚"
    },
    "on-click": "$WAYBAR_HOME/scripts/notifications/notifications-click.sh open",
    "on-click-right": "$WAYBAR_HOME/scripts/notifications/notifications-click.sh dnd",
    "on-click-middle": "$WAYBAR_HOME/scripts/notifications/notifications-click.sh settings"
  },
  "custom/screenshot": {
    "format": "{}",
    "return-type": "json",
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/capture/screenshot-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/capture/screenshot-click.sh select \"$WAYBAR_OUTPUT_NAME\"",
    "on-click-right": "$WAYBAR_HOME/scripts/capture/screenshot-click.sh full \"$WAYBAR_OUTPUT_NAME\"",
    "on-click-middle": "$WAYBAR_HOME/scripts/capture/screenshot-click.sh window \"$WAYBAR_OUTPUT_NAME\""
  },
  "custom/screenrecord": {
    "format": "{}",
    "return-type": "json",
    "signal": 6,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/capture/screenrecord-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/capture/screenrecord-click.sh select \"$WAYBAR_OUTPUT_NAME\"",
    "on-click-right": "$WAYBAR_HOME/scripts/capture/screenrecord-click.sh full \"$WAYBAR_OUTPUT_NAME\"",
    "on-click-middle": "$WAYBAR_HOME/scripts/capture/screenrecord-click.sh window \"$WAYBAR_OUTPUT_NAME\""
  },
  "custom/nightlight": {
    "format": "{}",
    "return-type": "json",
    "signal": 14,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/services/desktop/nightlight-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/services/desktop/nightlight-toggle.sh toggle",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/desktop/nightlight-toggle.sh force_toggle",
    "on-click-right": "$WAYBAR_HOME/scripts/services/desktop/nightlight-toggle.sh settings"
  },
  "custom/clipboard": {
    "format": "{0}{icon}",
    "return-type": "json",
    "signal": 9,
    "interval": "once",
    "escape": true,
    "exec": "$WAYBAR_HOME/scripts/notifications/clipboard-status.sh",
    "format-icons": {
      "normal": "󰅌",
      "empty": "󰅍",
      "disabled": "󰅌",
      "unknown": "󰅌"
    },
    "on-click": "$WAYBAR_HOME/scripts/notifications/clipboard-click.sh open",
    "on-click-right": "$WAYBAR_HOME/scripts/notifications/clipboard-click.sh clear",
    "on-click-middle": "$WAYBAR_HOME/scripts/notifications/clipboard-click.sh edit"
  },
  "custom/brightness": {
    "format": "{}",
    "return-type": "json",
    "signal": 8,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/lib/compositor-gate.sh --hide hyprland -- $WAYBAR_HOME/scripts/system/brightness-status.sh \"$WAYBAR_OUTPUT_NAME\"",
    "on-click": "$WAYBAR_HOME/scripts/system/brightness-control.sh adjust -5 \"$WAYBAR_OUTPUT_NAME\"",
    "on-click-right": "$WAYBAR_HOME/scripts/system/brightness-control.sh adjust +5 \"$WAYBAR_OUTPUT_NAME\"",
    "on-click-middle": "$WAYBAR_HOME/scripts/system/brightness-control.sh set 80 \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-up": "$WAYBAR_HOME/scripts/system/brightness-control.sh adjust +5 \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-down": "$WAYBAR_HOME/scripts/system/brightness-control.sh adjust -5 \"$WAYBAR_OUTPUT_NAME\""
  },
  "custom/powerprofiles": {
    "format": "{}",
    "return-type": "json",
    "signal": 3,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/system/powerprofiles-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/system/powerprofiles-click.sh menu",
    "on-click-right": "$WAYBAR_HOME/scripts/system/powerprofiles-click.sh power-saver",
    "on-click-middle": "$WAYBAR_HOME/scripts/system/powerprofiles-click.sh balanced",
    "on-scroll-up": "$WAYBAR_HOME/scripts/system/powerprofiles-click.sh next",
    "on-scroll-down": "$WAYBAR_HOME/scripts/system/powerprofiles-click.sh next"
  },
  "custom/asusctl": {
    "format": "{}",
    "return-type": "json",
    "tooltip": true,
    "signal": 28,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/system/asusctl-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/system/asusctl-click.sh menu",
    "on-click-right": "$WAYBAR_HOME/scripts/system/asusctl-click.sh next",
    "on-click-middle": "$WAYBAR_HOME/scripts/system/asusctl-status.sh --refresh",
    "on-scroll-up": "$WAYBAR_HOME/scripts/system/asusctl-click.sh next",
    "on-scroll-down": "$WAYBAR_HOME/scripts/system/asusctl-click.sh prev"
  },
  "custom/discord": {
    "format": "{}",
    "return-type": "json",
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/services/apps/discord-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/app-open.sh discord",
    "on-click-right": "$WAYBAR_HOME/scripts/services/apps/discord-click.sh mute",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/apps/discord-click.sh deafen"
  },
  "custom/lock": {
    "format": "",
    "tooltip": "Lock screen",
    "on-click": "$WAYBAR_HOME/scripts/system/power-click.sh lock"
  },
  "custom/power-menu": {
    "format": "󰐦",
    "tooltip": "Power menu (rofi grid)\nLock · Logout · Suspend · Reboot · Shutdown",
    "on-click": "$WAYBAR_HOME/scripts/system/power-click.sh menu"
  },
  "custom/logout": {
    "format": "󰍃",
    "tooltip": "Logout session",
    "on-click": "$WAYBAR_HOME/scripts/system/power-click.sh logout"
  },
  "custom/suspend": {
    "format": "󰤄",
    "tooltip": "Suspend system",
    "on-click": "$WAYBAR_HOME/scripts/system/power-click.sh suspend"
  },
  "custom/reboot": {
    "format": "󰜉",
    "tooltip": "Reboot system",
    "on-click": "$WAYBAR_HOME/scripts/system/power-click.sh reboot"
  },
  "custom/shutdown": {
    "format": "󰐥",
    "tooltip": "Shutdown system",
    "on-click": "$WAYBAR_HOME/scripts/system/power-click.sh shutdown"
  },
  "custom/kdeconnect": {
    "format": "{}",
    "return-type": "json",
    "signal": 18,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/services/devices/kdeconnect-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/services/devices/kdeconnect-status.sh --ring",
    "on-click-right": "$WAYBAR_HOME/scripts/services/devices/kdeconnect-menu.sh",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/devices/kdeconnect-status.sh --refresh && $WAYBAR_HOME/scripts/lib/waybar-signal.sh 18"
  },
  "custom/device-notifier": {
    "format": "{}",
    "return-type": "json",
    "signal": 19,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/services/devices/device-notifier-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/services/devices/device-notifier.py --menu",
    "on-click-right": "$WAYBAR_HOME/scripts/services/devices/device-notifier-status.sh --refresh && $WAYBAR_HOME/scripts/lib/waybar-signal.sh 19"
  },
  "custom/colorpicker": {
    "format": "󰏘",
    "tooltip": "Color Picker · Click to grab color",
    "on-click": "$WAYBAR_HOME/scripts/capture/color-picker.sh"
  },
  "custom/rgb": {
    "format": "{}",
    "return-type": "json",
    "tooltip": true,
    "signal": 30,
    "interval": 30,
    "exec": "$WAYBAR_HOME/scripts/system/rgb-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/app-open-key.sh openrgb",
    "on-click-right": "$WAYBAR_HOME/scripts/tools/app-open-key.sh ckb_next",
    "on-click-middle": "$WAYBAR_HOME/scripts/system/rgb-status.sh --refresh"
  },
  "custom/vaults": {
    "format": "{}",
    "return-type": "json",
    "signal": 21,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/services/security/vaults-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/services/security/vaults.py --menu",
    "on-click-right": "$WAYBAR_HOME/scripts/services/security/vaults-status.sh --refresh && $WAYBAR_HOME/scripts/lib/waybar-signal.sh 21"
  },
  "custom/touchpad": {
    "format": "{}",
    "return-type": "json",
    "signal": 20,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/lib/compositor-gate.sh --show hyprland -- $WAYBAR_HOME/scripts/system/touchpad-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/system/touchpad.py --toggle",
    "on-click-right": "$WAYBAR_HOME/scripts/system/touchpad-status.sh --refresh && $WAYBAR_HOME/scripts/lib/waybar-signal.sh 20"
  },
  "custom/weather": {
    "format": "{}",
    "return-type": "json",
    "interval": 1800,
    "exec": "$WAYBAR_HOME/scripts/services/apps/weather-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/app-open.sh xdg-open https://open-meteo.com/",
    "on-click-right": "$WAYBAR_HOME/scripts/tools/app-open.sh xdg-open https://weather.com/",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/apps/weather-status.sh --refresh"
  },
  "custom/pomodoro": {
    "format": "{}",
    "return-type": "json",
    "signal": 31,
    "interval": 1,
    "exec": "$WAYBAR_HOME/scripts/tools/pomodoro-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/pomodoro-click.sh toggle",
    "on-click-right": "$WAYBAR_HOME/scripts/tools/pomodoro-click.sh reset",
    "on-click-middle": "$WAYBAR_HOME/scripts/tools/pomodoro-click.sh skip"
  },
  "custom/systemd": {
    "format": "{}",
    "return-type": "json",
    "interval": 60,
    "exec": "$WAYBAR_HOME/scripts/system/systemd-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/app-open.sh ghostty -e bash -c \"echo \\\"Failed System Services:\\\"; systemctl --failed; echo \\\"\\\"; echo \\\"Failed User Services:\\\"; systemctl --user --failed; echo \\\"\\\"; read -p \\\"Press Enter to close... \\\"\""
  },
  "custom/github": {
    "format": "{}",
    "return-type": "json",
    "interval": 300,
    "exec": "$WAYBAR_HOME/scripts/services/apps/github-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/app-open.sh xdg-open https://github.com/notifications",
    "on-click-right": "$WAYBAR_HOME/scripts/tools/app-open.sh xdg-open https://github.com",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/apps/github-status.sh --refresh"
  },
  "custom/device-battery": {
    "format": "{}",
    "return-type": "json",
    "signal": 4,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/services/devices/device-battery-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/tools/app-open.sh solaar",
    "on-click-right": "$WAYBAR_HOME/scripts/tools/app-open-key.sh input_settings",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/devices/device-battery-status.sh --refresh"
  },
  "custom/streamdeck": {
    "format": "{}",
    "return-type": "json",
    "signal": 24,
    "interval": "once",
    "tooltip": true,
    "exec": "$WAYBAR_HOME/scripts/services/devices/streamdeck-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/services/devices/streamdeck-click.sh open",
    "on-click-right": "$WAYBAR_HOME/scripts/services/devices/streamdeck-click.sh restart",
    "on-click-middle": "$WAYBAR_HOME/scripts/services/devices/streamdeck-click.sh refresh"
  }
}
