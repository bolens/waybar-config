{
  "custom/dock-windows": {
    "format": "{}",
    "return-type": "json",
    "min-length": 64,
    "max-length": 160,
    "expand": true,
    "align": 0.5,
    "signal": 11,
    "interval": 120,
    "exec": "$WAYBAR_HOME/scripts/dock/dock-windows-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/dock/dock-windows-click.sh activate",
    "on-click-right": "$WAYBAR_HOME/scripts/dock/dock-windows-click.sh close-focused",
    "on-click-middle": "$WAYBAR_HOME/scripts/dock/dock-windows-click.sh cycle",
    "tooltip": true
  }
}
