    "on-click": "$HOME/.config/waybar/scripts/workspaces-click.sh 0 \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-up": "$HOME/.config/waybar/scripts/workspaces-click.sh scroll-up \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-down": "$HOME/.config/waybar/scripts/workspaces-click.sh scroll-down \"$WAYBAR_OUTPUT_NAME\"",
    "tooltip": true
