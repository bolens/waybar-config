{
  "custom/workspaces": {
    "format": "{text}",
    "return-type": "json",
    "signal": 16,
    "interval": "once",
    "hide-empty-text": true,
    "exec-on-event": true,
    "exec": "$HOME/.config/waybar/scripts/workspaces-status.sh \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-up": "$HOME/.config/waybar/scripts/workspaces-click.sh scroll-up \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-down": "$HOME/.config/waybar/scripts/workspaces-click.sh scroll-down \"$WAYBAR_OUTPUT_NAME\"",
    "tooltip": true
  },
  "custom/ws-0": {
    "format": "{text}",
