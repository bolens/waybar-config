{
  "custom/active-window": {
    "format": "{}",
    "return-type": "json",
    "escape": true,
    "exec": "$WAYBAR_HOME/scripts/workspaces/active-window-scroll.sh \"$WAYBAR_OUTPUT_NAME\"",
    "tooltip": true,
    "on-click": "$WAYBAR_HOME/scripts/workspaces/window-switcher.sh \"$WAYBAR_OUTPUT_NAME\""
  }
}
