{
  "custom/workspaces": {
    "format": "{text}",
    "return-type": "json",
    "signal": 16,
    "interval": "once",
    "hide-empty-text": true,
    "exec-on-event": true,
    "exec": "$WAYBAR_HOME/scripts/workspaces/workspaces-status.sh \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-up": "$WAYBAR_HOME/scripts/workspaces/workspaces-click.sh scroll-up \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-down": "$WAYBAR_HOME/scripts/workspaces/workspaces-click.sh scroll-down \"$WAYBAR_OUTPUT_NAME\"",
    "tooltip": true
  },
  "custom/ws-0": {
    "format": "{text}",
    "return-type": "json",
    "signal": 16,
    "interval": "once",
    "hide-empty-text": true,
    "exec-on-event": true,
    "exec": "$WAYBAR_HOME/scripts/workspaces/workspaces-slot-status.sh 0 \"$WAYBAR_OUTPUT_NAME\"",
    "on-click": "$WAYBAR_HOME/scripts/workspaces/workspaces-click.sh 0 \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-up": "$WAYBAR_HOME/scripts/workspaces/workspaces-click.sh scroll-up \"$WAYBAR_OUTPUT_NAME\"",
    "on-scroll-down": "$WAYBAR_HOME/scripts/workspaces/workspaces-click.sh scroll-down \"$WAYBAR_OUTPUT_NAME\"",
    "tooltip": true
  },
