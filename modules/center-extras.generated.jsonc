{
  "custom/keyboard-layout": {
    "format": "{}",
    "return-type": "json",
    "signal": 2,
    "interval": "once",
    "exec": "/home/panda/.config/waybar/scripts/keyboard-layout-status.sh",
    "on-click": "/home/panda/.config/waybar/scripts/keyboard-layout-click.sh next",
    "on-click-right": "/home/panda/.config/waybar/scripts/keyboard-layout-click.sh prev",
    "on-scroll-up": "/home/panda/.config/waybar/scripts/keyboard-layout-click.sh prev",
    "on-scroll-down": "/home/panda/.config/waybar/scripts/keyboard-layout-click.sh next",
    "tooltip": true
  },
  "custom/gamemode": {
    "format": "{}",
    "return-type": "json",
    "signal": 15,
    "interval": "once",
    "exec": "/home/panda/.config/waybar/scripts/gamemode-status.sh",
    "on-click": "/home/panda/.config/waybar/scripts/gamemode-click.sh toggle",
    "on-click-right": "/home/panda/.config/waybar/scripts/gamemode-click.sh restore",
    "tooltip": true
  },
  "custom/keybindhint": {
    "format": "{}",
    "return-type": "json",
    "interval": "once",
    "exec": "/home/panda/.config/waybar/scripts/keybindhint-status.sh",
    "on-click": "/home/panda/.config/waybar/scripts/keybindhint-click.sh",
    "tooltip": true
  }
}
