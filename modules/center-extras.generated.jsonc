{
  "custom/keyboard-layout": {
    "format": "{}",
    "return-type": "json",
    "signal": 2,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/keyboard-layout-status.sh",
    "tooltip": true
  },
  "custom/gamemode": {
    "format": "{}",
    "return-type": "json",
    "signal": 15,
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/gamemode-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/gamemode-click.sh toggle",
    "on-click-right": "$WAYBAR_HOME/scripts/gamemode-click.sh restore",
    "tooltip": true
  },
  "custom/keybindhint": {
    "format": "{}",
    "return-type": "json",
    "interval": "once",
    "exec": "$WAYBAR_HOME/scripts/keybindhint-status.sh",
    "on-click": "$WAYBAR_HOME/scripts/keybindhint-click.sh",
    "tooltip": true
  }
}
