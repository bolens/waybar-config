{"custom/vpnstatus":{"format":"{}","return-type":"json","interval":"once","signal":5,"exec":"$WAYBAR_HOME/scripts/network/vpn-status.sh","on-click":"python3 $WAYBAR_HOME/scripts/network/vpn-status-popup.py"},"custom/tailscale":{"format":"{}","return-type":"json","interval":"once","signal":12,"exec":"$WAYBAR_HOME/scripts/network/tailscale-status.sh","on-click":"$WAYBAR_HOME/scripts/tools/app-open.sh ghostty -e tailscale status","on-click-right":"$WAYBAR_HOME/scripts/tools/app-open.sh xdg-open http://100.100.100.100/"},"custom/i2pd":{"format":"{}","return-type":"json","interval":30,"signal":25,"tooltip":true,"exec":"$WAYBAR_HOME/scripts/services/i2pd/i2pd-status.sh","on-click":"$WAYBAR_HOME/scripts/tools/app-open.sh xdg-open http://127.0.0.1:7070","on-click-right":"$WAYBAR_HOME/scripts/tools/app-open.sh systemctl restart i2pd.service","on-click-middle":"$WAYBAR_HOME/scripts/services/i2pd/i2pd-status.sh --refresh"}}
