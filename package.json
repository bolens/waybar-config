{
  "name": "waybar-config",
  "private": true,
  "description": "DevDependencies for CSS/Markdown lint in CI and make check",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "lint:css": "stylelint \"style.css\" \"user-style.css\" \"theme.css\" \"theme/**/*.css\" --ignore-pattern \"**/*.generated.css\" --ignore-pattern \"theme/rofi/**\"",
    "lint:md": "markdownlint-cli2"
  },
  "devDependencies": {
    "markdownlint-cli2": "0.23.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0"
  }
}
