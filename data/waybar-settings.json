


{
  "bars": {
    "layer": "overlay",
    "output": ["*"],
    "exclusive": true,
    "passthrough": false,
    "reload_style_on_change": true,
    "height": 44,
    "spacing": 6,
    "tooltip": true,
    
    
    "floating": false,
    "margin_top": 8,
    "margin_right": 12,
    "margin_bottom": 0,
    "margin_left": 12,
    "glass_opacity": null, 
    "chrome_radius": null 
  },
  "drawers": {
    "click_to_reveal": true,
    "transition_duration": 500,
    "children_class": "drawer-child",
    "left_to_right": {
      "left": false,
      "right": true
    },
    "icons": {
      "desk": { "format": "󰍜", "tooltip": "Session controls" },
      "dock": { "format": "󰀻", "tooltip": "Applications" },
      "tray": { "format": "󰇝", "tooltip": "Background apps" },
      "media": { "format": "󰝚", "tooltip": "Media & volume" },
      "net": { "format": "󰖩", "tooltip": "Network" },
      "tools": { "format": "󰒓", "tooltip": "Quick tools" },
      "infra": { "format": "󰒍", "tooltip": "Infrastructure" },
      "hardware": { "format": "󰻠", "tooltip": "Hardware" },
      "power": { "format": "", "tooltip": "Power menu" },
      "privacy": { "format": "󰕥", "tooltip": "Privacy" },
      "security": { "format": "󰒃", "tooltip": "Security" }
    }
  },
  "module_intervals": {
    "dock_apps": "once",
    "notifications": "once",
    "screenshot": "once",
    "screenrecord": "once",
    "nightlight": "once",
    "clipboard": "once",
    "brightness": "once",
    "powerprofiles": "once",
    "asusctl": "once",
    "discord": "once",
    "mic": "once",
    "vpn": "once",
    "tailscale": "once",
    "privacy": "once",
    "keyboard_layout": "once",
    "gamemode": "once",
    "dock_windows": "once",
    "hypr_tools": "once",
    "hyprwhspr": 30,
    "cpu": 8,
    "gpu": 12,
    "memory": 12,
    "docker": 30,
    "ups": 30,
    "runtimes": 600,
    "updates": 1800,
    "disk": 300,
    "uptime": 60,
    "kdeconnect": "once",
    "device_notifier": "once",
    "touchpad": "once",
    "vaults": "once",
    "weather": 1800,
    "systemd": 60,
    "github": 300,
    "network_iface": 60,
    "network_bandwidth": 5,
    "clock": 60,
    "psu": 30,
    "device_battery": "once",
    "fans": 30,
    "liquidctl": 60,
    "coolercontrol": 60,
    "nvme": 30,
    "openlinkhub": 60,
    "rgb": 30,
    "libredefender": 300,
    "chkrootkit": 300,
    "syncthing": "once",
    "sunshine": 30,
    "streamdeck": "once",
    "i2pd": "once",
    "pomodoro": 1,
    "homelab": 60,
    "cava": 0,
    "album_art": 5,
    "stats_carousel": 2
  },
  "signals": {
    "notifications": 10,
    "screenrecord": 6,
    "nightlight": 14,
    "clipboard": 9,
    "brightness": 8,
    "mic": 7,
    "gamemode": 15,
    "dock_windows": 11,
    "dock_apps": 26,
    "privacy": 17,
    "workspaces": 16,
    "keyboard_layout": 2,
    "powerprofiles": 3,
    "device_battery": 4,
    "vpn": 5,
    "tailscale": 12,
    "kdeconnect": 18,
    "device_notifier": 19,
    "touchpad": 20,
    "vaults": 21,
    "updates": 1,
    "syncthing": 22,
    "sunshine": 23,
    "streamdeck": 24,
    "i2pd": 25,
    "coolercontrol": 27,
    "asusctl": 28,
    "openlinkhub": 29,
    "rgb": 30,
    "pomodoro": 31,
    "homelab": 33,
    "stats_carousel": 32
  },
  "layouts": {
    "top": {
      "position": "top",
      "modules_left": ["group/desk-controls", "group/media", "group/net"], 
      "modules_center": ["group/desk-hypr", "custom/keybindhint", "custom/gamemode"],
      "modules_right": ["group/top-status", "group/power"]
    },
    "bottom": {
      "name": "bottom",
      "position": "bottom",
      "modules_left": ["group/dock-apps"],
      "modules_center": ["custom/active-window"],
      "modules_right": ["group/tools", "group/infra", "group/security", "group/hardware", "clock#bottom"]
    }
  },
  "groups": {
    "power": {
      "drawer": "left",
      "modules": [
        "custom/power-drawer",
        "custom/power-menu",
        "custom/lock",
        "custom/logout",
        "custom/suspend",
        "custom/reboot",
        "custom/shutdown"
      ]
    },
    "desk-controls": {
      "drawer": "right",
      "modules": [
        "custom/desk-drawer",
        "custom/notifications",
        "custom/powerprofiles",
        "custom/asusctl",
        "custom/brightness",
        "bluetooth",
        "idle_inhibitor",
        "custom/keyboard-layout",
        "custom/kdeconnect",
        "custom/device-notifier",
        "custom/streamdeck",
        "custom/vaults",
        "custom/touchpad",
        "custom/device-battery"
      ]
    },
    "media": {
      "drawer": "right",
      "modules": ["custom/media-drawer", "custom/cava", "custom/media-prev", "custom/mpris", "custom/media-next", "pulseaudio", "custom/mic"]
    },
    "net": {
      "drawer": "right",
      "modules": [
        "custom/net-drawer",
        "network#bandwidthUpBytes",
        "network#bandwidthDownBytes",
        "custom/vpnstatus",
        "custom/tailscale",
        "custom/i2pd",
        "network#bond",
        "@network.interfaces"
      ]
    },
    "tools": {
      "drawer": "left",
      "modules": [
        "custom/tools-drawer",
        "custom/screenshot",
        "custom/screenrecord",
        "custom/nightlight",
        "custom/clipboard",
        "custom/colorpicker",
        "custom/rgb",
        "custom/discord",
        "custom/weather",
        "custom/pomodoro"
      ]
    },
    "top-status": {
      "modules": ["group/privacy", "group/tray-apps"]
    },
    "privacy": {
      "drawer": "left",
      "modules": [
        "custom/privacy-drawer",
        "custom/privacy-screenshare",
        "custom/privacy-webcam",
        "custom/privacy-audio-in",
        "custom/privacy-audio-out",
        "custom/privacy-location"
      ]
    },
    "tray-apps": {
      "drawer": "left",
      "modules": ["custom/tray-drawer", "tray"]
    },
    "infra": {
      "drawer": "left",
      "modules": [
        "custom/infra-drawer",
        "custom/homelab",
        "custom/docker",
        "custom/syncthing",
        "custom/sunshine",
        "custom/runtimes",
        "custom/updates",
        "custom/ups",
        "custom/systemd",
        "custom/github",
        "custom/uptime"
      ]
    },
    "hardware": {
      "drawer": "left",
      "modules": ["custom/hardware-drawer", "custom/cpu", "custom/gpu", "custom/memory", "custom/disk", "custom/nvme", "custom/psu", "custom/fans", "custom/liquidctl", "custom/coolercontrol", "custom/openlinkhub"]
    },
    "security": {
      "drawer": "left",
      "modules": [
        "custom/security-drawer",
        "custom/libredefender",
        "custom/chkrootkit"
      ]
    },
    "status": {
      "modules": ["clock#bottom"]
    }
  },
  "dock": {
    "section_order": ["web", "dev", "misc"]
  },
  "workspaces": {
    "slot_count": 5, 
    "scroll_per_output": true 
  },
  "dock_windows": {
    
    
    "enabled": true,
    "display": "icons", 
    "slot_count": 12, 
    "per_output": true, 
    "min_length": 8,
    "max_length": 48,
    "expand": true,
    "align": 0.5
  },
  "window_switcher": {
    "per_output": true 
  },
  "cava": {
    
    
    "bars": 8, 
    "framerate": 30,
    "placement": "drawer" 
  },
  "pomodoro": {
    "work_min": 25,
    "short_break_min": 5,
    "long_break_min": 15,
    "long_break_every": 4 
  },
  "homelab": {
    
    
    "timeout_sec": 3,
    "targets": []
  },
  "active_window": {
    "zscroll": true, 
    "max_length": 40, 
    "scroll_delay": 0.3, 
    "per_output": true 
  },
  "capture": {
    
    
    
    "screenshot_dir": null,
    "screenrecord_dir": null,
    "screenrecord_fps": 60, 
    "per_output": true 
  },
  "disk": {
    "path": "/" 
  },
  "liquidctl": {
    "match": "", 
    "pick": null, 
    
    "skip_corsair_psu_if_hwmon": true
  },
  "updates": {
    "preview_limit": 40, 
    "enable_aur": false 
  },
  "github": {
    "preview_limit": 5, 
    "show_reviews": true, 
    "on_click": null, 
    "on_click_right": null, 
    "on_click_middle": null 
  },
  "services": {
    "ups": {
      "nut_target": "ups@127.0.0.1:3493"
    },
    "chkrootkit": {
      "service_name": "chkrootkit-scan.service",
      "on_click": null, 
      "on_click_right": null 
    },
    "libredefender": {
      "service_name": "libredefender-scan.service",
      "on_click": null, 
      "on_click_right": null 
    },
    "syncthing": {
      "gui_url": "https://localhost:8384",
      "service_name": "syncthing", 
      "on_click": null, 
      "on_click_right": null 
    },
    "sunshine": {
      "gui_url": "https://localhost:47990",
      "service_name": "app-dev.lizardbyte.app.Sunshine.service",
      "on_click": null,
      "on_click_right": null
    },
    "i2pd": {
      "console_url": "http://127.0.0.1:7070/",
      "console_user": "i2pd",
      
      
      "service_name": "i2pd.service",
      "on_click": null,
      "on_click_right": null
    },
    "coolercontrol": {
      "api_url": "http://127.0.0.1:11987",
      "ui_url": "http://127.0.0.1:11987",
      "ui_user": "CCAdmin",
      
      
      
      "service_name": "coolercontrold.service",
      "on_click": null, 
      "on_click_right": null, 
      "on_click_middle": null, 
      "on_scroll_up": null, 
      "on_scroll_down": null 
    },
    "openlinkhub": {
      "api_url": "http://127.0.0.1:27003",
      "ui_url": "http://127.0.0.1:27003",
      "service_name": "openlinkhub.service",
      
      "prefer_presence": true,
      "on_click": null 
    }
  },
  "network": {
    "tailscale_admin_url": "http://100.100.100.100/",
    "tailscale_status_cmd": "ghostty -e tailscale status"
  },
  "brightness": {
    "step_down": 5,
    "step_up": 5,
    "middle_set": 80,
    "hide_on_compositor": "hyprland",
    "per_output": true, 
    "output_map": {} 
  },
  "audio": {
    "mpris_zscroll": true, 
    "mpris_max_length": 32, 
    "mpris_scroll_delay": 0.3, 
    "volume_step": 5, 
    "max_volume": 1.5, 
    "seek_back_sec": 30, 
    "seek_forward_sec": 10, 
    "pulseaudio_mute_cmd": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on_click": null, 
    "on_click_right": null 
  },
  "tray": {
    "icon_size": 16,
    "spacing": 10
  },
  "clocks": {
    "locale": "auto", 
    "hour_format": "12", 
    "date_format": "month-first", 
    "bottom": {
      "format": "auto",
      "tooltip_format": "auto"
    },
    "calendar": {
      "mode": "month",
      "on_scroll": 1,
      "first_day": "auto", 
      
      "colors": {
        "months": "#ff2a7f", 
        "weekdays": "#ffe600", 
        "days": "#c8f6ff", 
        "today": "#00e5ff" 
      },
      "format": {
        "months": "<span color='#ff2a7f'><b>{}</b></span>",
        "weekdays": "<span color='#ffe600'><b>{}</b></span>",
        "days": "<span color='#c8f6ff'>{}</span>",
        "today": "<span color='#00e5ff'><b><u>{}</u></b></span>"
      }
    }
  },
  "theme": {
    "mode": "static", 
    
    
    
    "preset": "cyberpunk", 
    "wallpaper": {
      "backend": "auto", 
      "scope": "per_output", 
      "image": null, 
      "outputs": {}, 
      "reload_style": true
    },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 13,
    "tooltip_font_size": 12,
    "border_radius": 8,
    "tooltip_padding": "8px 10px",
    "colors": {
      "foreground": "#c8f6ff",
      "background": "rgba(6, 7, 14, 0.92)",
      "border": "rgba(0, 229, 255, 0.25)",
      "accent": "#00e5ff", 
      "warning": "#ffe600",
      "critical": "#ff2a7f",
      "tooltip_background": "#06070e",
      "tooltip_border": "#005c66",
      "workspace_active": "rgba(255, 42, 127, 0.32)",
      "workspace_inactive": "rgba(200, 246, 255, 0.45)",
      "workspace_visible": "#00e5ff"
    }
  },
  "visual": {
    "gauges": { "enabled": true, "width": 8 },
    "album_art": { "enabled": true, "size": 22 },
    "stats_carousel": {
      "enabled": false,
      "modules": ["cpu", "memory", "disk", "gpu"]
    },
    "animations": {
      "workspace_pulse": true,
      "critical_breathe": true,
      "idle_glow": false,
      
      
      "reduced_motion": "auto"
    }
  },
  "hypr_tools": {
    "hyprwhspr_record": "/usr/lib/hyprwhspr/config/hyprland/hyprwhspr-tray.sh record",
    "hyprwhspr_restart": "/usr/lib/hyprwhspr/config/hyprland/hyprwhspr-tray.sh restart",
    "hyprnotify_click": "hyprnotify show",
    "hyprlight_click": "hyprlight osd",
    "keybinds_config": null, 
    "submap_per_output": false, 
    "empty_desktop_per_output": true
  },
  "weather": {
    "provider": "auto", 
    "unit": "auto", 
    "location": "auto", 
    "latitude": null, 
    "longitude": null,
    "on_click": null, 
    "on_click_right": null, 
    "on_click_middle": null 
  },
  "bluetooth": {
    "on_click": null, 
    "on_click_right": null, 
    "on_click_middle": null 
  },
  "keyboard": {
    "on_click": null, 
    "on_click_right": null, 
    "on_click_middle": null, 
    "on_scroll_up": null, 
    "on_scroll_down": null 
  },
  "gamemode": {
    "on_click": null, 
    "on_click_right": null, 
    "on_click_middle": null 
  },
  "kdeconnect": {
    "on_click": null,
    "on_click_right": null,
    "on_click_middle": null
  },
  "device_notifier": {
    "on_click": null,
    "on_click_right": null
  },
  "colorpicker": {
    "on_click": null
  },
  "vaults": {
    "base_dir": null,
    "on_click": null,
    "on_click_right": null
  },
  "touchpad": {
    "on_click": null,
    "on_click_right": null
  },
  "thresholds": {
    "cpu": {
      "usage": { "warning": 60, "critical": 85 },
      "temp": { "warning": 75, "critical": 85 }
    },
    "gpu": {
      "util": { "warning": 70, "critical": 90 },
      "temp": { "warning": 75, "critical": 83 }
    },
    "memory": {
      "warning": 70,
      "critical": 85
    },
    "disk": {
      "warning": 75,
      "critical": 90
    },
    "fans": {
      "cpu": { "warning": 1600, "critical": 2000 },
      "gpu": { "warning": 70, "critical": 85 }
    },
    "liquidctl": {
      "temp": { "warning": 55, "critical": 65 } 
    },
    "coolercontrol": {
      "temp": { "warning": 75, "critical": 90 } 
    },
    "nvme": {
      "temp": { "warning": 60, "critical": 75 } 
    },
    "openlinkhub": {
      "temp": { "warning": 60, "critical": 75 }
    },
    "psu": {
      "temp": { "warning": 55, "critical": 65 }
    },
    "ups": {
      "charge": { "warning": 25, "critical": 10 } 
    },
    "updates": {
      "warning": 1, 
      "critical": 75
    },
    "device_battery": {
      "warning": 30, 
      "critical": 15
    }
  },
  "nightlight": {
    "temperature": 4200 
  },
  "rofi": {
    "theme": "$WAYBAR_HOME/theme/rofi/dock-rofi.rasi",
    "clipboard": {
      "width": 780,
      "lines": 18
    },
    "audio": {
      "width": 600
    },
    "bluetooth": {
      "width": 560,
      "lines": 16,
      "x_offset": -250,
      "y_offset": 0
    },
    "calendar": {
      "width": 420,
      "x_offset": -30,
      "y_offset": 0
    },
    "notifications": {
      "width": 650
    },
    "wifi": {
      "width": 560,
      "lines": 20,
      "x_offset": -270,
      "y_offset": 0
    },
    "switcher": {
      "width": 650
    },
    "updates": {
      "width": 650,
      "height": 500
    },
    "powerprofiles": {
      "width": 250,
      "lines": 3
    },
    "asusctl": {
      "width": 280,
      "lines": 4
    },
    "coolercontrol": {
      "width": 320,
      "lines": 6
    },
    "kdeconnect": {
      "width": 400
    },
    "vaults": {
      "width": 400
    },
    "device_notifier": {
      "width": 500
    }
  },
  "apps": {
    "clock": "kclock",
    "system_monitor": "missioncenter",
    "terminal": "ghostty",
    "plasma_system_monitor": "plasma-systemmonitor",
    "btop": "ghostty -e btop",
    "nvtop": "ghostty -e nvtop",
    "nvidia_smi": "ghostty -e nvidia-smi -l 1",
    "lazydocker": "lazydocker",
    "portainer_url": "https://portainer.bolens.dev",
    "docker_ps": "ghostty -e docker ps -a",
    "network_editor": "nm-connection-editor",
    "ip_addr": "ghostty -e ip -br a",
    "virt_manager": "virt-manager",
    "podman_ps": "ghostty -e podman ps -a",
    "virsh_list": "ghostty -e virsh list --all",
    "paru_update": "ghostty -e paru -Syu",
    "updates_review": "$WAYBAR_HOME/scripts/services/sync/updates-review.sh",
    "audio_mixer": "goxlr-launcher",
    "discord": "discord",
    "file_manager": "xdg-open $HOME",
    "github_notifications": "https://github.com/notifications",
    "github_home": "https://github.com",
    "solaar": "solaar",
    "openrgb": "openrgb",
    "ckb_next": "ckb-next",
    "input_settings": "systemsettings",
    "power_settings": "systemsettings",
    "privacy_settings": "systemsettings6 kcm_app-permissions",
    "camera_settings": "systemsettings6 kcm_kamera",
    "notifications_settings": "systemsettings6 kcm_notifications",
    "systemd_failed": "ghostty -e bash -c \"echo \\\"Failed System Services:\\\"; systemctl --failed; echo \\\"\\\"; echo \\\"Failed User Services:\\\"; systemctl --user --failed; echo \\\"\\\"; read -p \\\"Press Enter to close... \\\"\""
  },
  "streamdeck": {
    "service_name": "app-streamdeck-ui@autostart.service",
    "on_click": null,
    "on_click_right": null,
    "on_click_middle": null
  }
}
