// Local secrets overlay — copy to waybar-secrets.jsonc and fill in.
// waybar-secrets.jsonc is gitignored; never commit real credentials.
// Or run: sudo scripts/services/i2pd/i2pd-set-console-pass.sh
//   (imports [http] pass from i2pd.conf if secrets are empty; otherwise pushes secrets → conf)
{
  "services": {
    "i2pd": {
      "console_pass": "CHANGE_ME"
    }
  }
}
