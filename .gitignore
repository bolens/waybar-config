# Python
__pycache__/
*.py[cod]
*$py.class

# Editors / OS
*~
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary & lock files
*.tmp
*.tmp.*
*.bak
*.orig
*.lock.d/

# Node (stylelint / markdownlint)
node_modules/
.pnpm-store/

# Local env / credentials (belt-and-suspenders; secrets live under data/)
.env
.env.*
!.env.example

# Logs (runtime cache is under ~/.cache/waybar; keep any in-repo logs out)
*.log

# Runtime album cover (theme/album-art.generated.css uses relative url("album-art"))
/theme/album-art
/theme/album-art.*

# Exclude the dry-run folder with large tarballs
dry-run/

# Local secrets (merged over settings at read time — never commit)
data/waybar-secrets.json
data/waybar-secrets.jsonc
!data/waybar-secrets.example.jsonc

# Note: data/waybar-settings.json and *.generated.{jsonc,css} are compiled
# artifacts that ARE tracked so clones work before the first generate.

# OpenLinkHub host dumps sometimes land in the waybar config dir — never commit.
/config.json
/dashboard.json
/display.json
