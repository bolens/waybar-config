# Python files
__pycache__/
*.pyc
*.pyo
*.pyd

# Temporary & Lock files
*.tmp
*.tmp.*
*.lock.d/

# Waybar specific cached states & logs
vpn-status-debug.log
*.log

# Exclude the dry-run folder with large tarballs
dry-run/

# Local secrets (merged over settings at read time — never commit)
data/waybar-secrets.json
data/waybar-secrets.jsonc
!data/waybar-secrets.example.jsonc
